{
  "name": "qcloud2-client",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:noproxy" : "ng serve",
    "build": "ng build --prod",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "transpile": "ng build --prod --build-optimizer --aot",
    "transpile:dev": "ng build --prod --build-optimizer --configuration=dev --aot --base-href /qcloud2/",
    "transpile:test": "ng build --prod --build-optimizer --configuration=test --aot",
    "transpile:preprod": "ng build --prod --build-optimizer --aot --base-href /qcloud2/"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^7.0.0",
    "@angular/common": "^7.0.0",
    "@angular/compiler": "^7.0.0",
    "@angular/core": "^7.0.0",
    "@angular/forms": "^7.0.0",
    "@angular/http": "^7.0.0",
    "@angular/platform-browser": "^7.0.0",
    "@angular/platform-browser-dynamic": "^7.0.0",
    "@angular/router": "^7.0.0",
    "@auth0/angular-jwt": "^2.0.0",
    "core-js": "^2.5.7",
    "jwt-decode": "^2.2.0",
    "materialize-css": "^1.0.0",
    "moment": "^2.22.2",
    "ng2-dragula": "^1.5.0",
    "pickr-widget": "^0.3.1",
    "plotly.js": "^1.38.3",
    "rxjs": "^6.3.3",
    "sockjs-client": "^1.1.5",
    "stompjs": "^2.3.3",
    "zone.js": "^0.8.26"
  },
  "devDependencies": {
    "@angular/cli": "^7.0.2",
    "@angular/compiler-cli": "^7.0.0",
    "@angular/language-service": "^7.0.0",
    "@types/jasmine": "^2.8.8",
    "@types/jasminewd2": "~2.0.2",
    "@types/node": "^6.0.113",
    "angular-ide": "^0.9.41",
    "codelyzer": "^4.4.2",
    "jasmine-core": "~2.8.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "^2.0.4",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "^1.4.3",
    "karma-jasmine": "^1.1.2",
    "karma-jasmine-html-reporter": "^0.2.2",
    "protractor": "~5.1.2",
    "ts-node": "~4.1.0",
    "tslint": "~5.9.1",
    "typescript": "~3.1.3",
    "@angular-devkit/build-angular": "~0.6.8"
  }
}
